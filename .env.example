# ============================================================
# ATTENDIFY — Environment Variables
# ============================================================
# Copy this file to .env and fill in the values.
# NEVER commit the .env file to version control.
# All values below must be set in your Vercel project settings.
# ============================================================

# ── Firebase Client SDK Config (injected into frontend at build time) ──
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=

# ── Firebase Admin SDK (server-side only, NEVER exposed to frontend) ──
# Paste the entire service account JSON as a single-line string.
# Generate from: Firebase Console → Project Settings → Service Accounts → Generate New Private Key
FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"...","private_key":"...","client_email":"...","client_id":"...","auth_uri":"...","token_uri":"...","auth_provider_x509_cert_url":"...","client_x509_cert_url":"..."}

# ── Teacher Signup Code (server-side only, NEVER exposed to frontend) ──
# Teachers must enter this code during registration. Validated on the server.
TEACHER_SIGNUP_CODE=your-secret-teacher-code

# ── Attendance Checksum Secret (server-side only) ──
# Used to generate HMAC-SHA256 checksums for tamper detection.
# Generate a strong random string: openssl rand -hex 32
CHECKSUM_SECRET=
