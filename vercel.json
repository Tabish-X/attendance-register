{
  "version": 2,
  "buildCommand": "node build.js",
  "outputDirectory": ".",
  "routes": [
    { "src": "/api/auth/signup", "dest": "/api/auth.js?action=signup" },
    { "src": "/api/auth/login-check", "dest": "/api/auth.js?action=login-check" },
    { "src": "/api/classes/([^/]+)", "dest": "/api/classes.js?id=$1" },
    { "src": "/api/classes", "dest": "/api/classes.js" },
    { "src": "/api/divisions/regen-code", "dest": "/api/divisions.js?action=regen-code" },
    { "src": "/api/divisions/students", "dest": "/api/divisions.js?action=students" },
    { "src": "/api/divisions/([^/]+)", "dest": "/api/divisions.js?id=$1" },
    { "src": "/api/divisions", "dest": "/api/divisions.js" },
    { "src": "/api/subjects/([^/]+)", "dest": "/api/subjects.js?id=$1" },
    { "src": "/api/subjects", "dest": "/api/subjects.js" },
    { "src": "/api/attendance/tamper-check", "dest": "/api/attendance.js?action=tamper-check" },
    { "src": "/api/attendance/([^/]+)", "dest": "/api/attendance.js?id=$1" },
    { "src": "/api/attendance", "dest": "/api/attendance.js" },
    { "src": "/api/students/roll", "dest": "/api/students.js?action=roll" },
    { "src": "/api/students/join", "dest": "/api/students.js?action=join" },
    { "src": "/api/students/links", "dest": "/api/students.js?action=links" },
    { "src": "/api/students/overview", "dest": "/api/students.js?action=overview" },
    { "src": "/api/students/subject-attendance", "dest": "/api/students.js?action=subject-attendance" },
    { "src": "/api/students/profile", "dest": "/api/students.js?action=profile" },
    { "src": "/api/reports/session", "dest": "/api/reports.js?action=session" },
    { "src": "/api/reports/class-report", "dest": "/api/reports.js?action=class-report" },
    { "src": "/", "dest": "/index.html" },
    { "src": "/teacher", "dest": "/teacher.html" },
    { "src": "/student", "dest": "/student.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://www.gstatic.com https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src https://fonts.gstatic.com; connect-src 'self' https://*.googleapis.com https://*.firebaseio.com https://*.firebaseapp.com; img-src 'self' data:;"
        },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
      ]
    }
  ]
}
